---
import BhargavLayout from "../../layouts/BhargavLayout.astro";

const photography = [
  { src: "/images/photo-01.png", alt: "Photography placeholder 1" },
  { src: "/images/photo-02.png", alt: "Photography placeholder 2" },
  { src: "/images/photo-03.png", alt: "Photography placeholder 3" }
];

const paintings = [
  { src: "/images/painting-01.png", alt: "Painting placeholder 1" },
  { src: "/images/painting-02.png", alt: "Painting placeholder 2" },
  { src: "/images/painting-03.png", alt: "Painting placeholder 3" }
];
---

<BhargavLayout title="Bhargav">
  <main class="page">
    <section class="bhargav-hero">
      <div class="bhargav-intro">
        <div class="kicker">Photography · Painting · Ongoing work</div>
        <h1>Bhargav</h1>
        <p class="hero-text">
          Working primarily through photography, with painting and photobook work
          unfolding alongside it.
        </p>
      </div>

      <div class="bhargav-note">
        A quiet visual practice shaped by atmosphere, sequence and observation.
      </div>
    </section>
  </main>

  <section class="gallery-section">
    <div class="carousel-title">Photography</div>
    <div class="carousel-viewport">
      <div class="carousel-track">
        {photography.concat(photography).map((img) => (
          <div class="carousel-item">
            <img src={img.src} alt={img.alt} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="gallery-section">
    <div class="carousel-title">Paintings</div>
    <div class="carousel-viewport">
      <div class="carousel-track">
        {paintings.concat(paintings).map((img) => (
          <div class="carousel-item">
            <img src={img.src} alt={img.alt} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bhargav-meta">
    <div class="meta-block">
      <h2>Photobook</h2>
      <p>
        An ongoing long-form body of work exploring sequence, image relationships
        and narrative through photography.
      </p>
    </div>

    <div class="meta-block">
      <h2>Exhibitions</h2>
      <ul>
        <li>Exhibition Name — City, Year</li>
        <li>Art Fair Name — Year</li>
        <li>Group Show — Location</li>
      </ul>
    </div>
  </section>
</BhargavLayout>