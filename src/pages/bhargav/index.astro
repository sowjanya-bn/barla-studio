---
import BhargavLayout from "../../layouts/BhargavLayout.astro";
const base = import.meta.env.BASE_URL;

const photography = [

  { src: `${base}/images/photo-01.png`, alt: "Photography placeholder 1" },
  { src: `${base}/images/photo-02.png`, alt: "Photography placeholder 2" },
  { src: `${base}/images/photo-03.png`, alt: "Photography placeholder 3" }
];

const paintings = [
  { src: `${base}/images/painting-01.png`, alt: "Painting placeholder 1" },
  { src: `${base}/images/painting-02.png`, alt: "Painting placeholder 2" },
  { src: `${base}/images/painting-03.png`, alt: "Painting placeholder 3" }
];
---

<BhargavLayout title="Bhargav">
  <main class="page">
    <section class="bhargav-hero">
      <div class="bhargav-intro">
        <div class="kicker">Photography · Painting · Ongoing work</div>
        <h1>Bhargav</h1>

        <p class="hero-statement">
          A body of work rooted in coastal memory — interpreted through light and shadow.
        </p>

        <p class="hero-text">
          Working primarily through photography, with painting and photobook work unfolding alongside it.
        </p>

        <p class="hero-context">
          Rooted in Visakhapatnam, now shaped at a distance.
        </p>
      </div>

      <div class="bhargav-note">
        A quiet visual practice shaped by atmosphere, sequence and observation.
      </div>
    </section>
  </main>

  <section class="gallery-section gallery-section--photo">
    <div class="carousel-title">Photography</div>
    <p class="section-subtitle">
      Moments shaped by light, haze and movement along the coast.
    </p>

    <div class="carousel-viewport">
      <div class="carousel-track">
        {photography.concat(photography).map((img) => (
          <div class="carousel-item">
            <img src={img.src} alt={img.alt} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="narrative-bridge">
    <p>
      The coast appears differently depending on when you arrive — early morning haze,
      harsh midday light, or the quiet after sunset.
    </p>
    <p>
      These works explore how light reveals, softens and sometimes obscures what is seen.
    </p>
  </section>

  <section class="gallery-section gallery-section--painting">
    <div class="carousel-title">Paintings</div>
    <p class="section-subtitle">
      Studies in light, shadow and tonal contrast.
    </p>

    <div class="carousel-viewport">
      <div class="carousel-track">
        {paintings.concat(paintings).map((img) => (
          <div class="carousel-item">
            <img src={img.src} alt={img.alt} />
          </div>
        ))}
      </div>
    </div>
  </section>
</BhargavLayout>