---
import BhargavLayout from "../../../layouts/BhargavLayout.astro";
---

<BhargavLayout title="Contact | Bhargav">
  <main class="content-page">
    <header class="content-header">
      <div class="section-kicker">Contact</div>
      <h1 class="page-title">Get in touch</h1>
      <p class="content-intro">
        Open to conversations around exhibitions, collaborations and ongoing work.
      </p>
    </header>

    <section class="content-block">
      <div class="contact-links">
        <a class="contact-link" href="mailto:bhargav@example.com">Email</a>
        <a class="contact-link" href="https://instagram.com/your-instagram" target="_blank" rel="noreferrer">Instagram</a>
      </div>
    </section>
  </main>
</BhargavLayout>