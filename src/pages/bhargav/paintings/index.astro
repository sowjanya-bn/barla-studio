---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const works = [
  { title: "Earth Tones I", note: "Muted layers and balanced composition", image: "/images/paint-01.svg" },
  { title: "Field Memory", note: "Soft edges, weight and surface", image: "/images/paint-02.svg" },
  { title: "Still Form", note: "Minimal gesture and quieter marks", image: "/images/paint-03.svg" }
];
---

<BaseLayout title="Bhargav | Paintings" description="Selected paintings by Bhargav.">
  <div class="shell">
    <header class="topbar">
      <div class="brand"><a href="/bhargav/">Bhargav</a></div>
      <nav class="nav">
        <a href="/bhargav/">Overview</a>
        <a href="/bhargav/photography/">Photography</a>
        <a href="/bhargav/books/">Photo books</a>
      </nav>
    </header>

    <main>
      <section class="page-intro">
        <div class="kicker">Paintings</div>
        <h1>Works on surface</h1>
        <p>A calm, gallery-like page for selected paintings, series notes and medium information.</p>
      </section>

      <section class="grid-3">
        {works.map((work) => (
          <article class="gallery-card">
            <div class="thumb"><img src={work.image} alt={work.title} /></div>
            <div class="meta">Painting</div>
            <h3>{work.title}</h3>
            <p>{work.note}</p>
          </article>
        ))}
      </section>
    </main>

    <div class="footer-note">This page can later become a full paintings index or a selection page with individual work detail routes.</div>
  </div>
</BaseLayout>
