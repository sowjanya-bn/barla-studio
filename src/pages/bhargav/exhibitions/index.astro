---
import BhargavLayout from "../../../layouts/BhargavLayout.astro";
---

<BhargavLayout title="Exhibitions | Bhargav">
  <main class="content-page">
    <header class="content-header">
      <div class="section-kicker">Public work</div>
      <h1 class="page-title">Exhibitions</h1>
      <p class="content-intro">
        Selected exhibitions, art fairs and upcoming events.
      </p>
    </header>

    <section class="content-block">
      <h2>Selected exhibitions</h2>
      <ul class="link-list">
        <li>Exhibition Name — City, Year</li>
        <li>Group Show — Location, Year</li>
      </ul>
    </section>

    <section class="content-block">
      <h2>Art fairs</h2>
      <ul class="link-list">
        <li>Art Fair Name — City, Year</li>
        <li>Fair Name — Year</li>
      </ul>
    </section>

    <section class="content-block">
      <h2>Upcoming</h2>
      <ul class="link-list">
        <li>Upcoming Event — Venue, Date</li>
      </ul>
    </section>
  </main>
</BhargavLayout>