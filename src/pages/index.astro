---
import BaseLayout from "../layouts/BaseLayout.astro";
---

---
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Barla Studio" description="A shared home with independent paths for Sowjanya and Bhargav.">
  <div class="shell">

    <main>
      <section class="hero">
        <div class="hero-copy">
          <div class="kicker">Shared host, separate worlds</div>
          <h1 class="display">Two independent pages under one quiet roof.</h1>
          <p class="lead">
            This root page does not need to act as a formal landing page. It simply holds the shared
            premise while each path keeps its own tone, layout and visual language.
          </p>
          <div class="actions">
            <a href={`${base}sowjanya/`}>Sowjanya</a>
            <a href={`${base}bhargav/`}>Bhargav</a>
          </div>
          <div class="quote">Minimal systems on one side. Image, atmosphere and books on the other.</div>
        </div>

        <div class="hero-visual">
          <img src={`${base}images/shared-premise.svg`}  alt="Abstract split composition suggesting two distinct creative paths" />
        </div>
      </section>
    </main>

    <div class="footer-note">You can later simplify this page even further or turn it into a blank redirect-style entry.</div>
  </div>
</BaseLayout>
