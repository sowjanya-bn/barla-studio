---
import SowjanyaLayout from "../../layouts/SowjanyaLayout.astro";

const links = {
  github: "https://github.com/sowjanya-bn",
  linkedin: "https://www.linkedin.com/in/naga-sowjanya-barla/",
  email: "mailto:nagasowjanya.barla@gmail.com",
  paper: "https://arxiv.org/abs/2604.02545"
};
---

<SowjanyaLayout title="Naga Sowjanya Barla">
  <div class="site-shell">

    <main class="page">

      <section class="page-header">
        <div class="page-copy">
          <div class="kicker">Systems · Data · AI · Quietly built</div>
          <h1>Naga<br/>Sowjanya<br/>Barla</h1>
          <div class="hero-accent"></div>

          <p class="hero-text">
            I build systems. For a long time that meant backend and distributed systems.
            Lately, I've been drawn to how structured knowledge, retrieval and language models
            can be shaped into systems that actually behave well.
            I care about clarity, structure and things making sense.
          </p>

          <blockquote class="quote-block">
            Curious. Always after simplicity and clarity.
          </blockquote>
        </div>

        <aside class="hero-side">
          <div class="mini-card">
            <div class="mini-title">Focus</div>
            <ul>
              <li>Systems that are simple on the surface, well-structured underneath</li>
              <li>Backend and distributed architectures</li>
              <li>Data and structured representations of information</li>
              <li>AI systems that are grounded, not just impressive</li>
            </ul>
          </div>

          <div class="mini-card">
            <div class="mini-title">Now</div>
            <p>
              Interested in systems that remain simple, stable and predictable,
              even as they grow.
            </p>
          </div>
        </aside>
      </section>

      <section class="card-grid">

        <article class="card">
          <h2>Recent Work</h2>

          <div class="work-item">
            <h3>RAG-based Digital Storytelling</h3>
            <p>
              Exploring how structured knowledge graphs and retrieval pipelines can be combined
              with language models to produce grounded, narrative outputs.
            </p>
            <a href={links.github} target="_blank" rel="noreferrer">View project →</a>
          </div>

          <div class="work-item">
            <h3>KG + SPARQL Retrieval Experiments</h3>
            <p>
              Working through different ways of retrieving and structuring knowledge for use
              in LLM workflows, focusing on grounding and consistency.
            </p>
          </div>

          <div class="work-item">
            <h3>RAG Evaluation and Behaviour</h3>
            <p>
              Looking at how to evaluate retrieval-augmented systems beyond surface-level
              correctness, with a focus on coverage and coherence.
            </p>
          </div>
        </article>

        <article class="card">
          <h2>Experience</h2>
          <p>
            Over a decade building backend systems in telecom and enterprise environments.
            APIs, integrations and distributed systems — getting different parts of a system
            to talk to each other reliably and predictably.
            That way of thinking still shapes how I approach everything else.
          </p>
        </article>

        <article class="card">
          <h2>Publications</h2>
          <span class="pub-badge">Accepted · ESWC 2026</span>
          <h3>Competency Questions as Executable Plans</h3>
          <p style="margin: 0.5rem 0 1rem;">
            Controlled RAG architecture for cultural heritage storytelling.
            arXiv preprint.
          </p>
          <a class="button" href={links.paper} target="_blank" rel="noreferrer">
            View paper →
          </a>
        </article>

      </section>

    </main>

    <footer class="site-footer">
      <span>Naga Sowjanya Barla</span>
      <a href="/" style="font-size:0.78rem; opacity:0.6;">← Barla Studio</a>
    </footer>

  </div>
</SowjanyaLayout>
