---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Barla Studio" description="Two independent creative paths under one quiet roof.">
  <div class="landing-wrap">
    <header class="landing-header">
      <span class="landing-wordmark">Barla Studio</span>
      <span class="landing-tagline">Two paths · One roof</span>
    </header>

    <main class="landing-hero">
      <!-- Sowjanya panel -->
      <a href={`${base}/sowjanya/`} class="panel panel--sowjanya">
        <span class="panel-num" aria-hidden="true">I</span>
        <div class="panel-content">
          <p class="panel-kicker">Systems · Data · AI</p>
          <h2 class="panel-name">Sowjanya</h2>
          <p class="panel-desc">
            Building systems that are simple on the surface, well-structured underneath.
            Backend, distributed architectures, and AI that behaves well.
          </p>
          <span class="panel-link">
            Enter
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 8h10M9 4l4 4-4 4"/>
            </svg>
          </span>
        </div>
      </a>

      <div class="landing-or" aria-hidden="true">or</div>

      <!-- Bhargav panel -->
      <a href={`${base}/bhargav/`} class="panel panel--bhargav">
        <span class="panel-num" aria-hidden="true">II</span>
        <div class="panel-content">
          <p class="panel-kicker">Photography · Painting · Photobook</p>
          <h2 class="panel-name">Bhargav</h2>
          <p class="panel-desc">
            A visual practice rooted in coastal memory — interpreted through light,
            atmosphere and the quiet between moments.
          </p>
          <span class="panel-link">
            Enter
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 8h10M9 4l4 4-4 4"/>
            </svg>
          </span>
        </div>
      </a>
    </main>

    <footer class="landing-footer">
      <span>Barla Studio — shared host, separate worlds</span>
      <span>© 2025</span>
    </footer>
  </div>
</BaseLayout>
