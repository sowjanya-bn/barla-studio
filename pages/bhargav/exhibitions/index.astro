---
import BhargavLayout from "../../../layouts/BhargavLayout.astro";
---

<BhargavLayout title="Exhibitions | Bhargav">
  <main class="content-page">

    <header class="content-header">
      <div class="kicker">Public work</div>
      <h1>Exhibitions</h1>
      <p class="content-intro">
        Selected exhibitions, art fairs and upcoming events.
      </p>
    </header>

    <div class="exh-grid">

      <section class="exh-section">
        <h2>Selected exhibitions</h2>
        <div class="exh-list">
          <div class="exh-item">
            <div class="exh-meta">
              <span class="exh-year">—</span>
            </div>
            <div class="exh-detail">
              <h3>Exhibition Name</h3>
              <p>City, Year</p>
            </div>
          </div>
          <div class="exh-item">
            <div class="exh-meta">
              <span class="exh-year">—</span>
            </div>
            <div class="exh-detail">
              <h3>Group Show</h3>
              <p>Location, Year</p>
            </div>
          </div>
        </div>
      </section>

      <section class="exh-section">
        <h2>Art fairs</h2>
        <div class="exh-list">
          <div class="exh-item">
            <div class="exh-meta">
              <span class="exh-year">—</span>
            </div>
            <div class="exh-detail">
              <h3>Art Fair Name</h3>
              <p>City, Year</p>
            </div>
          </div>
          <div class="exh-item">
            <div class="exh-meta">
              <span class="exh-year">—</span>
            </div>
            <div class="exh-detail">
              <h3>Fair Name</h3>
              <p>Year</p>
            </div>
          </div>
        </div>
      </section>

      <section class="exh-section exh-section--upcoming">
        <h2>Upcoming</h2>
        <div class="exh-list">
          <div class="exh-item exh-item--upcoming">
            <div class="upcoming-badge">Soon</div>
            <div class="exh-detail">
              <h3>Upcoming Event</h3>
              <p>Venue, Date</p>
            </div>
          </div>
        </div>
      </section>

    </div>

  </main>
</BhargavLayout>

<style>
  .content-page {
    position: relative;
    z-index: 1;
    max-width: var(--max);
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) var(--gutter) 5rem;
  }

  .content-header {
    border-bottom: 1px solid var(--line);
    padding-bottom: 2rem;
    margin-bottom: 3rem;
  }

  .content-header h1 {
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin: 0.6rem 0 0;
    color: var(--ink);
  }

  .content-intro {
    font-size: 0.97rem;
    color: var(--ink-soft);
    max-width: 40rem;
    margin-top: 0.8rem;
    line-height: 1.8;
  }

  /* Grid */
  .exh-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .exh-section {
    background: rgba(255,255,255,0.42);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 1.8rem 2rem;
    backdrop-filter: blur(6px);
    transition: border-color 0.25s ease, transform 0.25s ease;
  }

  .exh-section:hover {
    border-color: rgba(160, 82, 45, 0.28);
    transform: translateY(-2px);
  }

  .exh-section--upcoming {
    grid-column: 1 / -1;
    background: rgba(160, 82, 45, 0.04);
    border-color: rgba(160, 82, 45, 0.2);
  }

  .exh-section h2 {
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    color: var(--ink);
    margin-bottom: 1.4rem;
    letter-spacing: -0.02em;
  }

  /* List items */
  .exh-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .exh-item {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--line);
    transition: padding-left 0.25s ease;
  }

  .exh-item:last-child { border-bottom: none; }

  .exh-item:hover { padding-left: 0.5rem; }

  .exh-meta { flex-shrink: 0; }

  .exh-year {
    font-family: 'Playfair Display', serif;
    font-size: 0.85rem;
    color: var(--sienna-light);
    font-style: italic;
  }

  .exh-detail h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.2rem;
  }

  .exh-detail p {
    font-size: 0.85rem;
    color: var(--ink-soft);
  }

  /* Upcoming */
  .exh-item--upcoming {
    align-items: center;
  }

  .upcoming-badge {
    flex-shrink: 0;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(160, 82, 45, 0.1);
    color: var(--sienna);
    border: 1px solid rgba(160, 82, 45, 0.25);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
  }

  @media (max-width: 700px) {
    .exh-grid { grid-template-columns: 1fr; }
    .exh-section--upcoming { grid-column: 1; }
  }
</style>
