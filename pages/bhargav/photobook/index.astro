---
import BhargavLayout from "../../../layouts/BhargavLayout.astro";
const base = import.meta.env.BASE_URL;

const images = [
  { src: `${base}/images/photo-01.png`, alt: "Coastal study 1" },
  { src: `${base}/images/photo-02.png`, alt: "Coastal study 2" },
  { src: `${base}/images/photo-03.png`, alt: "Coastal study 3" },
  { src: `${base}/images/painting-01.png`, alt: "Study 4" },
  { src: `${base}/images/painting-02.png`, alt: "Study 5" },
];
---

<BhargavLayout title="Photobook | Bhargav">
  <main class="content-page">

    <header class="content-header">
      <div class="kicker">In progress</div>
      <h1>Photobook</h1>
      <p class="content-intro">
        A long-form body of work exploring sequence, memory and place through photography.
      </p>
    </header>

    <!-- Hero spread -->
    <div class="photobook-spread">
      {images.slice(0, 2).map((img, i) => (
        <div class={`spread-img spread-img--${i === 0 ? 'large' : 'small'}`}>
          <img src={img.src} alt={img.alt} loading="lazy" />
        </div>
      ))}
    </div>

    <!-- Body content -->
    <div class="content-cols">
      <section class="content-block">
        <h2>Current direction</h2>
        <p>
          This project is developing as an extended visual sequence shaped by coastal memory,
          atmosphere and recurrence. More details and previews will be added as the work evolves.
        </p>
      </section>

      <section class="content-block">
        <h2>Notes</h2>
        <p>
          The photobook gathers images into a slower narrative space, where light, distance
          and place can be held in relation rather than as isolated frames.
        </p>
        <p style="margin-top: 0.8rem;">
          Working with sequence means working with rhythm — how one image prepares you for
          the next, and what lingers in the space between.
        </p>
      </section>
    </div>

    <!-- Secondary image row -->
    <div class="photobook-row">
      {images.slice(2).map((img) => (
        <div class="row-img">
          <img src={img.src} alt={img.alt} loading="lazy" />
        </div>
      ))}
    </div>

  </main>
</BhargavLayout>

<style>
  .content-page {
    position: relative;
    z-index: 1;
    max-width: var(--max);
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) var(--gutter) 5rem;
  }

  .content-header {
    border-bottom: 1px solid var(--line);
    padding-bottom: 2rem;
    margin-bottom: 2.5rem;
  }

  .content-header h1 {
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin: 0.6rem 0 0;
    color: var(--ink);
  }

  .content-intro {
    font-size: 0.97rem;
    color: var(--ink-soft);
    max-width: 42rem;
    margin-top: 0.8rem;
    line-height: 1.8;
  }

  /* Hero spread */
  .photobook-spread {
    display: grid;
    grid-template-columns: 1.55fr 1fr;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .spread-img {
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
  }

  .spread-img img {
    width: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .spread-img--large img { aspect-ratio: 16/10; }
  .spread-img--small img { aspect-ratio: 3/4; }

  .spread-img:hover img { transform: scale(1.02); }

  /* Content cols */
  .content-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .content-block h2 {
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    color: var(--ink);
    margin-bottom: 0.8rem;
    letter-spacing: -0.02em;
  }

  .content-block p {
    font-size: 0.93rem;
    color: var(--ink-soft);
    line-height: 1.85;
  }

  /* Secondary row */
  .photobook-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .row-img {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s ease;
  }

  .row-img:hover { transform: translateY(-3px); }

  .row-img img {
    width: 100%;
    aspect-ratio: 1 / 1.1;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 760px) {
    .photobook-spread { grid-template-columns: 1fr; }
    .content-cols { grid-template-columns: 1fr; }
    .photobook-row { grid-template-columns: 1fr 1fr; }
  }
</style>
