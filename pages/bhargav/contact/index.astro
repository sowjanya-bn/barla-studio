---
import BhargavLayout from "../../../layouts/BhargavLayout.astro";
---

<BhargavLayout title="Contact | Bhargav">
  <main class="content-page">

    <header class="content-header">
      <div class="kicker">Reach out</div>
      <h1>Get in touch</h1>
      <p class="content-intro">
        Open to conversations around exhibitions, collaborations and ongoing work.
      </p>
    </header>

    <div class="contact-layout">

      <div class="contact-links-wrap">
        <a class="contact-link" href="mailto:barla09@gmail.com">
          <span class="contact-link__icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="1" y="3" width="14" height="10" rx="2"/>
              <path d="M1 5l7 5 7-5"/>
            </svg>
          </span>
          <span class="contact-link__label">Email</span>
          <span class="contact-link__value">barla09@gmail.com</span>
        </a>

        <a class="contact-link" href="https://www.instagram.com/bhargavbarla/" target="_blank" rel="noreferrer">
          <span class="contact-link__icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="1" y="1" width="14" height="14" rx="3.5"/>
              <circle cx="8" cy="8" r="3"/>
              <circle cx="11.5" cy="4.5" r="0.75" fill="currentColor" stroke="none"/>
            </svg>
          </span>
          <span class="contact-link__label">Instagram</span>
          <span class="contact-link__value">@bhargavbarla</span>
        </a>
      </div>

      <div class="contact-note">
        <p>
          Work is ongoing. Responses may take a few days.
        </p>
        <p>
          Interested in prints, collaborations, or exhibiting together? Please include
          context in your message.
        </p>
      </div>

    </div>

  </main>
</BhargavLayout>

<style>
  .content-page {
    position: relative;
    z-index: 1;
    max-width: var(--max);
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) var(--gutter) 5rem;
  }

  .content-header {
    border-bottom: 1px solid var(--line);
    padding-bottom: 2rem;
    margin-bottom: 3rem;
  }

  .content-header h1 {
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin: 0.6rem 0 0;
    color: var(--ink);
  }

  .content-intro {
    font-size: 0.97rem;
    color: var(--ink-soft);
    max-width: 40rem;
    margin-top: 0.8rem;
    line-height: 1.8;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
    max-width: 860px;
  }

  /* Contact link cards */
  .contact-links-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1.4rem 1.6rem;
    background: rgba(255,255,255,0.45);
    border: 1px solid var(--line);
    border-radius: 16px;
    backdrop-filter: blur(8px);
    color: var(--ink);
    transition: all 0.25s ease;
    box-shadow: var(--shadow-sm);
  }

  .contact-link:hover {
    background: rgba(255,255,255,0.7);
    border-color: rgba(160, 82, 45, 0.3);
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }

  .contact-link__icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sienna);
    flex-shrink: 0;
  }

  .contact-link__label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  .contact-link__value {
    font-size: 0.8rem;
    color: var(--ink-soft);
    text-align: right;
  }

  /* Note block */
  .contact-note {
    padding: 1.6rem 1.8rem;
    border-left: 2px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .contact-note p {
    font-size: 0.93rem;
    color: var(--ink-soft);
    line-height: 1.85;
  }

  @media (max-width: 700px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .contact-link {
      grid-template-columns: auto 1fr;
    }
    .contact-link__value { display: none; }
  }
</style>
